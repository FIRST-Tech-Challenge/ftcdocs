{
    "tasks": [
        {
            "type": "shell",
            "label": "make-setup",
            "command": "nix",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "develop",
                "--command",
                "true"
            ],
            "group": {
                "kind": "build",
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "make-html",
            "command": "nix",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "develop",
                "--command",
                "make",
                "-C",
                "docs",
                "html"
            ],
            "group": {
                "kind": "build",
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "make-latexpdf",
            "command": "nix",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "develop",
                "--command",
                "make",
                "-C",
                "docs",
                "latexpdf"
            ],
            "group": {
                "kind": "build",
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "make-autobuild",
            "command": "nix",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "develop",
                "--command",
                "make",
                "-C",
                "docs",
                "autobuild"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "make-clean",
            "command": "nix",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "develop",
                "--command",
                "make",
                "-C",
                "docs",
                "clean"
            ],
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}
